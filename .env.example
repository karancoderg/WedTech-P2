# Environment Variables for WedSync
# Copy this file to .env.local and fill in the values

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_YOUR_KEY_HERE
CLERK_SECRET_KEY=sk_test_YOUR_KEY_HERE
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Encryption (for SMTP password storage)
ENCRYPTION_KEY=YOUR_ENCRYPTION_KEY

# Gemini API Key (Required for AI Seating Plan)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# Tabbly AI Call Support (Required for AI RSVPs)
TABBLY_API_KEY=YOUR_TABBLY_API_KEY
TABBLY_ORGANIZATION_ID=YOUR_ORGANIZATION_ID
TABBLY_AGENT_ID=YOUR_AGENT_ID
TABBLY_CALL_FROM_NUMBER=YOUR_CALL_FROM_NUMBER
TABBLY_WEBHOOK_SECRET=YOUR_TABBLY_WEBHOOK_SECRET

GROQ_API_KEY=YOUR_GROQ_API_KEY